e(\"date('CreatedDate_Year', 'CreatedDate_Month', 'CreatedDate_Day')\")}};\nAppl_curr = filter Applications by {{row(dateSelector_1.selection, [0], [\"min\", \"max\"]).asDateRange(\"date('AppliedDate_Year', 'AppliedDate_Month', 'AppliedDate_Day')\")}};\nAppl_Returned_curr = filter Appl_curr by 'WasReturned' == \"true\";\nLicense_curr = filter BusinessLicense by {{row(dateSelector_1.selection, [0], [\"min\", \"max\"]).asDateRange(\"date('PeriodStart_Year', 'PeriodStart_Month', 'PeriodStart_Day')\")}};\n---Compare to Duration\nTxnFee_prev = filter TxnFee by {{row(dateSelector_2.selection, [0], [\"min\", \"max\"]).asDateRange(\"date('CreatedDate_Year', 'CreatedDate_Month', 'CreatedDate_Day')\")}};\nAppl_prev = filter Applications by {{row(dateSelector_2.selection, [0], [\"min\", \"max\"]).asDateRange(\"date('AppliedDate_Year', 'AppliedDate_Month', 'AppliedDate_Day')\")}};\nAppl_Returned_prev = filter Appl_prev by 'WasReturned' == \"true\";\nLicense_prev = filter BusinessLicense by {{row(dateSelector_2.selection, [0], [\"min\", \"max\"]).asDateRange(\"date('PeriodStart_Year', 'PeriodStart_Month', 'PeriodStart_Day')\")}};\n---Cogroup all the streams\nresult = cogroup TxnFee_curr by all full, Appl_curr by all full, Appl_Returned_curr by all full, License_curr by all full,TxnFee_prev by all full,Appl_prev by all full,Appl_Returned_prev by all full,License_prev by all ;\nresult = foreach result generate sum(TxnFee_curr.'TotalFeeAmount') as 'Total_Revenue',count(Appl_curr) as 'Total_Applications_Received',count(License_curr) as 'Total_Licenses_Issued',count('Appl_Returned_curr') as 'Total_Applications_Reassigned',sum(TxnFee_prev.'TotalFeeAmount') as 'Total_Revenue_prev',count(Appl_prev) as 'Total_Applications_Received_prev',count(License_prev) as 'Total_Licenses_Issued_prev',count('Appl_Returned_prev') as 'Total_Applications_Reassigned_prev' ;\nfinal = foreach result generate 'Total_Revenue','Total_Applications_Received','Total_Licenses_Issued','Total_Applications_Reassigned','Total_Revenue_prev','Total_Applications_Received_prev','Total_Licenses_Issued_prev','Total_Applications_Reassigned_prev',(('Total_Revenue'- 'Total_Revenue_prev')/'Total_Revenue_prev') as 'perc_Revenue_Change',(('Total_Applications_Received'- 'Total_Applications_Received_prev')/'Total_Applications_Received_prev') as 'perc_Applications_Received_Change',(('Total_Licenses_Issued'- 'Total_Licenses_Issued_prev')/'Total_Licenses_Issued_prev') as 'perc_Licenses_Issued_Change',(('Total_Applications_Reassigned'- 'Total_Applications_Reassigned_prev')/'Total_Applications_Reassigned_prev') as 'perc_Applications_Reassigned_Change';","receiveFacetSource":{"mode":"exclude","steps":["dateSelector_1","dateSelector_2"]},"selectMode":"single","strings":[],"type":"saql","useExternalFilters":false,"useGlobal":true,"visualizationParameters":{"parameters":{"borderColor":"#e0e5ee","borderWidth":1,"cell":{"backgroundColor":"#ffffff","fontColor":"#16325c","fontSize":12},"columnProperties":{},"columns":[],"customBulkActions":[],"header":{"backgroundColor":"#f4f6f9","fontColor":"#16325c","fontSize":12},"headerProperties":{},"innerMajorBorderColor":"#a8b7c7","innerMinorBorderColor":"#e0e5ee","interactions":[],"maxColumnWidth":300,"minColumnWidth":40,"mode":"variable","numberOfLines":1,"showActionMenu":true,"showRowIndexColumn":false,"totals":true,"verticalPadding":8},"type":"table"}},"Performance_Over_Per_3":{"broadcastFacet":true,"groups":[],"label":"Performance_Over_Period","numbers":[],"query":"Bus_License = load \"BusinessLicense_FEN\";\nApplications = load \"Applications_FEN\";{{cell(static_Perf_Over_Per_1.selection, 0, \"Filter\").asObject()}};\nInspection = load \"Inspection_FEN\";\nPublicComplaint = load \"PublicComplaint_FEN\";\nViolation = load \"RegulatoryCodeViolation_FEN\";\nBus_License_curr = filter Bus_License by {{row(dateSelector_1.selection, [0], [\"min\", \"max\"]).asDateRange(\"date('PeriodStart_Year', 'PeriodStart_Month', 'PeriodStart_Day')\")}};\nBus_License_prev = filter Bus_License by {{row(dateSelector_2.selection, [0], [\"min\", \"max\"]).asDateRange(\"date('PeriodStart_Year', 'PeriodStart_Month', 'PeriodStart_Day')\")}};\nApplications_curr = filter Applications by {{row(dateSelector_1.selection, [0], [\"min\", \"max\"]).asDateRange(\"date('AppliedDate_Year', 'AppliedDate_Month', 'AppliedDate_Day')\")}};\nApplications_prev = filter Applications by {{row(dateSelector_2.selection, [0], [\"min\", \"max\"]).asDateRange(\"date('AppliedDate_Year', 'AppliedDate_Month', 'AppliedDate_Day')\")}};\nInspection_curr = filter Inspection by {{row(dateSelector_1.selection, [0], [\"min\", \"max\"]).asDateRange(\"date('ActualVisitStartTime_Year', 'ActualVisitStartTime_Month', 'ActualVisitStartTime_Day')\")}};\nInspection_prev = filter Inspection by {{row(dateSelector_2.selection, [0], [\"min\", \"max\"]).asDateRange(\"date('ActualVisitStartTime_Year', 'ActualVisitStartTime_Month', 'ActualVisitStartTime_Day')\")}};\nPublicComplaint_curr = filter PublicComplaint by {{row(dateSelector_1.selection, [0], [\"min\", \"max\"]).asDateRange(\"date('CreatedDate_Year', 'CreatedDate_Month', 'CreatedDate_Day')\")}};\nPublicComplaint_prev = filter PublicComplaint by {{row(dateSelector_2.selection, [0], [\"min\", \"max\"]).asDateRange(\"date('CreatedDate_Year', 'CreatedDate_Month', 'CreatedDate_Day')\")}};\nViolation_curr = filter Violation by {{row(dateSelector_1.selection, [0], [\"min\", \"max\"]).asDateRange(\"date('CreatedDate_Year', 'CreatedDate_Month', 'CreatedDate_Day')\")}};\nViolation_prev = filter Violation by {{row(dateSelector_2.selection, [0], [\"min\", \"max\"]).asDateRange(\"date('CreatedDate_Year', 'CreatedDate_Month', 'CreatedDate_Day')\")}};\nresult = group Bus_License_curr by 'PeriodStart_Quarter' full, Bus_License_prev by 'PeriodStart_Quarter' full,'Applications_curr' by 'AppliedDate_Quarter' full,'Applications_prev' by 'AppliedDate_Quarter' full,'Inspection_curr' by 'ActualVisitStartTime_Quarter' full,'Inspection_prev' by 'ActualVisitStartTime_Quarter' full,'PublicComplaint_curr' by 'CreatedDate_Quarter' full,'PublicComplaint_prev' by 'CreatedDate_Quarter' full,'Violation_curr' by 'CreatedDate_Quarter' full, 'Violation_prev' by 'CreatedDate_Quarter';\nresult = foreach result generate coalesce(Bus_License_curr.'PeriodStart_Quarter', Bus_License_prev.'PeriodStart_Quarter',Applications_curr.'AppliedDate_Quarter',Applications_prev.'AppliedDate_Quarter',Inspection_curr.'ActualVisitStartTime_Quarter',Inspection_prev.'ActualVisitStartTime_Quarter',PublicComplaint_curr.'CreatedDate_Quarter',PublicComplaint_prev.'CreatedDate_Quarter',Violation_curr.'CreatedDate_Quarter',Violation_prev.'CreatedDate_Quarter') as 'PeriodStart_Quarter', count(Bus_License_curr) as 'Current_Duration_License', count(Bus_License_prev) as 'Compare_To_Duration_License',count('Applications_curr') as 'Current_Duration_Applications',count('Applications_prev') as 'Compare_To_Duration_Applications',count('Inspection_curr') as 'Current_Duration_Inspections',count('Inspection_prev') as 'Compare_To_Duration_Inspections',count('PublicComplaint_curr') as 'Current_Duration_Complaints', count('PublicComplaint_prev') as 'Compare_To_Duration_Complaints', count('Violation_curr') as 'Current_Duration_Violations',count('Violation_prev') as 'Compare_To_Duration_Violations';\nfinal = foreach result generate 'PeriodStart_Quarter',sum('Current_Duration_{{cell(static_Perf_Over_Per_1.selection, 0, \"Measure_Name\").asString()}}') as 'Current_Duration_{{cell(static_Perf_Over_Per_1.selection, 0, \"Measure_Name\").asString()}}', sum('Compare_To_Duration_{{cell(static_Perf_Over_Per_1.selection, 0, \"Measure_Name\").asString()}}') as 'Compare_To_Duration_{{cell(static_Perf_Over_Per_1.selection, 0, \"Measure_Name\").asString()}}';\nfinal = order final by ('PeriodStart_Quarter' asc);\n--result = limit result 2000;","receiveFacetSource":{"mode":"exclude","steps":["dateSelector_2","dateSelector_1"]},"selectMode":"single","start":"[]","strings":[],"type":"saql","useExt