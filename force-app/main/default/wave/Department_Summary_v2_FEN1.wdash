se_FEN\";\nApplications = load \"Applications_FEN\";\nApplications = filter Applications by {{cell(Performance_Over_Per_3.selection, 0, \"PeriodStart_Quarter\").asEquality(\"AppliedDate_Quarter\")}};{{cell(static_Perf_Over_Per_1.selection, 0, \"Filter\").asObject()}};\nInspection = load \"Inspection_FEN\";\nInspection = filter Inspection by {{cell(Performance_Over_Per_3.selection, 0, \"PeriodStart_Quarter\").asEquality(\"ActualVisitStartTime_Quarter\")}};\nPublicComplaint = load \"PublicComplaint_FEN\";\nPublicComplaint = filter PublicComplaint by {{cell(Performance_Over_Per_3.selection, 0, \"PeriodStart_Quarter\").asEquality(\"CreatedDate_Quarter\")}};\nViolation = load \"RegulatoryCodeViolation_FEN\";\nViolation = filter Violation by {{cell(Performance_Over_Per_3.selection, 0, \"PeriodStart_Quarter\").asEquality(\"CreatedDate_Quarter\")}};\nBus_License_curr = filter Bus_License by {{row(dateSelector_1.selection, [0], [\"min\", \"max\"]).asDateRange(\"date('PeriodStart_Year', 'PeriodStart_Month', 'PeriodStart_Day')\")}};\nBus_License_prev = filter Bus_License by {{row(dateSelector_2.selection, [0], [\"min\", \"max\"]).asDateRange(\"date('PeriodStart_Year', 'PeriodStart_Month', 'PeriodStart_Day')\")}};\nApplications_curr = filter Applications by {{row(dateSelector_1.selection, [0], [\"min\", \"max\"]).asDateRange(\"date('AppliedDate_Year', 'AppliedDate_Month', 'AppliedDate_Day')\")}};\nApplications_prev = filter Applications by {{row(dateSelector_2.selection, [0], [\"min\", \"max\"]).asDateRange(\"date('AppliedDate_Year', 'AppliedDate_Month', 'AppliedDate_Day')\")}};\nInspection_curr = filter Inspection by {{row(dateSelector_1.selection, [0], [\"min\", \"max\"]).asDateRange(\"date('ActualVisitStartTime_Year', 'ActualVisitStartTime_Month', 'ActualVisitStartTime_Day')\")}};\nInspection_prev = filter Inspection by {{row(dateSelector_2.selection, [0], [\"min\", \"max\"]).asDateRange(\"date('ActualVisitStartTime_Year', 'ActualVisitStartTime_Month', 'ActualVisitStartTime_Day')\")}};\nPublicComplaint_curr = filter PublicComplaint by {{row(dateSelector_1.selection, [0], [\"min\", \"max\"]).asDateRange(\"date('CreatedDate_Year', 'CreatedDate_Month', 'CreatedDate_Day')\")}};\nPublicComplaint_prev = filter PublicComplaint by {{row(dateSelector_2.selection, [0], [\"min\", \"max\"]).asDateRange(\"date('CreatedDate_Year', 'CreatedDate_Month', 'CreatedDate_Day')\")}};\nViolation_curr = filter Violation by {{row(dateSelector_1.selection, [0], [\"min\", \"max\"]).asDateRange(\"date('CreatedDate_Year', 'CreatedDate_Month', 'CreatedDate_Day')\")}};\nViolation_prev = filter Violation by {{row(dateSelector_2.selection, [0], [\"min\", \"max\"]).asDateRange(\"date('CreatedDate_Year', 'CreatedDate_Month', 'CreatedDate_Day')\")}};\nresult = group Bus_License_curr by 'PeriodStart_Month' full, Bus_License_prev by 'PeriodStart_Month' full,'Applications_curr' by 'AppliedDate_Month' full,'Applications_prev' by 'AppliedDate_Month' full,'Inspection_curr' by 'ActualVisitStartTime_Month' full,'Inspection_prev' by 'ActualVisitStartTime_Month' full,'PublicComplaint_curr' by 'CreatedDate_Month' full,'PublicComplaint_prev' by 'CreatedDate_Month' full,'Violation_curr' by 'CreatedDate_Month' full, 'Violation_prev' by 'CreatedDate_Month';\nresult = foreach result generate coalesce(Bus_License_curr.'PeriodStart_Month', Bus_License_prev.'PeriodStart_Month',Applications_curr.'AppliedDate_Month',Applications_prev.'AppliedDate_Month',Inspection_curr.'ActualVisitStartTime_Month',Inspection_prev.'ActualVisitStartTime_Month',PublicComplaint_curr.'CreatedDate_Month',PublicComplaint_prev.'CreatedDate_Month',Violation_curr.'CreatedDate_Month',Violation_prev.'CreatedDate_Month') as 'PeriodStart_Month', count(Bus_License_curr) as 'Current_Duration_License', count(Bus_License_prev) as 'Compare_To_Duration_License',count('Applications_curr') as 'Current_Duration_Applications',count('Applications_prev') as 'Compare_To_Duration_Applications',count('Inspection_curr') as 'Current_Duration_Inspections',count('Inspection_prev') as 'Compare_To_Duration_Inspections',count('PublicComplaint_curr') as 'Current_Duration_Complaints', count('PublicComplaint_prev') as 'Compare_To_Duration_Complaints', count('Violation_curr') as 'Current_Duration_Violations',count('Violation_prev') as 'Compare_To_Duration_Violations';\nfinal = foreach result generate 'PeriodStart_Month',sum('Current_Duration_{{cell(static_Perf_Over_Per_1.selection, 0, \"Measure_Name\").asString()}}') as 'Current_Duration_{{cell(static_Perf_Over_Per_1.selection, 0, \"Measure_Name\").asString()}}', sum('Compare_To_Duration_{{cell(static_Perf_Over_Per_1.selection, 0, \"Measure_Name\").asString()}}') as 'Compare_To_Duration_{{cell(static_Perf_Over_Per_1.selection, 0, \"Measure_Name\").asString()}}';\nfinal = order final by ('PeriodStart_Month' asc);\n--result = limit result 2000;","receiveFacetSource":{"mode":"exclude","steps":["dateSelector_2","dateSelector_1"]},"selectMode":"single","start":"[]","strings":[],"type":"saql","useExternalFilters":false,"useGlobal":true,"visualizationParameters":{"parameters":{"autoFitMode":"keepLabels","stack":false,"showPoints":true,"legend":{"descOrder":false,"showHeader":true,"show":true,"customSize":"auto","position":"right-top","inside":false},"axisMode":"sync","tooltip":{"content":{"legend":{"showBinLabel":true,"measures":[],"showNullValues":true,"customizeLegend":false,"showPercentage":true,"showDimensions":true,"showMeasures":true,"dimensions":[]}}},"visualizationType":"time-combo","missingValue":"connect","timeAxis":{"showTitle":true,"showAxis":true,"title":""},"title":{"fontSize":14,"subtitleFontSize":11,"label":"","align":"center","subtitleLabel":""},"trellis":{"flipLabels":false,"showGridLines":true,"size":[100,100],"enable":false,"type":"x","chartsPerLine":4},"showActionMenu":true,"measureAxis2":{"sqrtScale":false,"showTitle":true,"showAxis":true,"title":"","customDomain":{"showDomain":false}},"measureAxis1":{"sqrtScale":false,"showTitle":false,"showA