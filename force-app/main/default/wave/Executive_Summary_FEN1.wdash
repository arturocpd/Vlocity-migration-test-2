ion, 0, \"AppliedDate_Month\").asEquality(\"CreatedDate_Month\")}};\r\nTotalFees_curr = filter TotalFees by {{row(AppliedDate_1.selection, [0], [\"min\", \"max\"]).asDateRange(\"date('CreatedDate_Year', 'CreatedDate_Month', 'CreatedDate_Day')\")}};\r\nTotalFees_prev = filter TotalFees by {{row(AppliedDate_2.selection, [0], [\"min\", \"max\"]).asDateRange(\"date('CreatedDate_Year', 'CreatedDate_Month', 'CreatedDate_Day')\")}};\r\nresult = group TotalFees_curr by all full, TotalFees_prev by all;\r\nresult = foreach result generate sum(TotalFees_curr.'TotalFeeAmount') as 'TotalFees', sum(TotalFees_prev.'TotalFeeAmount') as 'TotalFees_prev';\r\nfinal = foreach result generate 'TotalFees', ('TotalFees' - 'TotalFees_prev')/'TotalFees_prev' as 'perc_TotalFee_Change';","receiveFacetSource":{"mode":"exclude","steps":["ExecHerVizPage1_1","AppliedDate_1","AppliedDate_2","HeroVizPage2_1","Top5AccountsFees_1","ByRegulatoryTransact_1","FeeByLicenseType_2","RegAuthName_1","ActualInspectionsByD_1","DonutVizPage3Direct_1","IspectionsComplaints_1","ViolationsByViolatio_1","ComplaintsByComplain_1","PlannedInspections_1","KPI_bar_Page3_1","Fee_from_Inspections_1","Fee_by_Assets_1","RegulatoryTransactio_1"]},"selectMode":"single","strings":[],"type":"saql","useExternalFilters":false,"useGlobal":true,"visualizationParameters":{"parameters":{"borderColor":"#e0e5ee","borderWidth":1,"cell":{"backgroundColor":"#ffffff","fontColor":"#16325c","fontSize":12},"columnProperties":{},"columns":[],"customBulkActions":[],"header":{"backgroundColor":"#f4f6f9","fontColor":"#16325c","fontSize":12},"headerProperties":{},"innerMajorBorderColor":"#a8b7c7","innerMinorBorderColor":"#e0e5ee","interactions":[],"maxColumnWidth":300,"minColumnWidth":40,"mode":"variable","numberOfLines":1,"showActionMenu":true,"totals":true,"verticalPadding":8},"type":"table"}},"RegAuthName_1":{"broadcastFacet":true,"groups":[],"label":"RegAuthName","numbers":[],"query":"q = load \"RegulatoryTransactionFee_FEN\";\nq_a = group q by 'Application.RegAuthType.RegulatoryAuthority.Name';\nq_a = foreach q_a generate 'Application.RegAuthType.RegulatoryAuthority.Name' as 'Application.RegAuthType.RegulatoryAuthority.Name', sum('TotalFeeAmount') as 'sum_Fee';\nq_b = group q by 'BusinessLicense.RegAuthType.RegulatoryAuthority.Name';\nq_b = foreach q_b generate 'BusinessLicense.RegAuthType.RegulatoryAuthority.Name' as 'BusinessLicense.RegAuthType.RegulatoryAuthority.Name', sum('TotalFeeAmount') as 'sum_Fee';\nq_c = cogroup q_a by 'Application.RegAuthType.RegulatoryAuthority.Name' full,q_b by 'BusinessLicense.RegAuthType.RegulatoryAuthority.Name';\nq_c = foreach q_c generate coalesce(q_a.'Application.RegAuthType.RegulatoryAuthority.Name', q_b.'BusinessLicense.RegAuthType.RegulatoryAuthority.Name') as 'Application.RegAuthType.RegulatoryAuthority.Name', coalesce(sum(q_a.'sum_Fee'),0)+coalesce(sum(q_b.'sum_Fee'), 0) as 'TotalFeeAmount';\nq_c = order q_c by 'TotalFeeAmount' desc;","receiveFacetSource":{"mode":"exclude","steps":["RegulatoryTransactio_1","ExecHerVizPage1_1","Top5Accounts_1","CountOfBusinessTypes_1","FeeByLicenseType_1","NoOfAppsByRegulatory_1","ActualInspectionsByD_1","DonutVizPage3Direct_1","IspectionsComplaints_1","ViolationsByViolatio_1","ComplaintsByComplain_1","PlannedInspections_1","Fee_from_Inspections_1","KPI_bar_Page3_1","KPI_Bar_LicenseFees_1","KPI_BAR_Page1_1","Clone_of_ExecHerVizP_1","Name_1"]},"selectMode":"single","start":"[]","strings":[],"type":"saql","useExternalFilters":false,"useGlobal":true,"visualizationParameters":{"parameters":{"autoFitMode":"keepLabels","bins":{"breakpoints":{"high":100,"low":0},"bands":{"high":{"color":"#008000","label":""},"low":{"color":"#B22222","label":""},"medium":{"color":"#ffa500","label":""}}},"legend":{"descOrder":false,"showHeader":false,"show":true,"customSize":"auto","position":"bottom-center","inside":false},"axisMode":"multi","tooltip":{"content":{"legend":{"showBinLabel":true,"measures":[],"showNullValues":true,"customizeLegend":false,"s