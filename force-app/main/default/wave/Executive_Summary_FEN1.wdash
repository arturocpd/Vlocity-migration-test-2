ctualInspectionsByD_1.selection, 0, \"ActualVisitStartTime_Month\").asEquality(\"CreatedDate_Month\")}};\r\n\r\n---Duration Data\r\nInsp_curr = filter Insp by {{row(AppliedDate_1.selection, [0], [\"min\", \"max\"]).asDateRange(\"date('ActualVisitStartTime_Year', 'ActualVisitStartTime_Month', 'ActualVisitStartTime_Day')\")}};\r\nRegCdViolation_curr = filter RegCdViolation by {{row(AppliedDate_1.selection, [0], [\"min\", \"max\"]).asDateRange(\"date('CreatedDate_Year', 'CreatedDate_Month', 'CreatedDate_Day')\")}};\r\nEnfAction_curr = filter EnfAction by {{row(AppliedDate_1.selection, [0], [\"min\", \"max\"]).asDateRange(\"date('CreatedDate_Year', 'CreatedDate_Month', 'CreatedDate_Day')\")}};\r\nPublicComplaint_curr = filter PublicComplaint by {{row(AppliedDate_1.selection, [0], [\"min\", \"max\"]).asDateRange(\"date('CreatedDate_Year', 'CreatedDate_Month', 'CreatedDate_Day')\")}};\r\n\r\n---Compare to Duration\r\nInsp_prev = filter Insp by {{row(AppliedDate_2.selection, [0], [\"min\", \"max\"]).asDateRange(\"date('ActualVisitStartTime_Year', 'ActualVisitStartTime_Month', 'ActualVisitStartTime_Day')\")}};\r\nRegCdViolation_prev = filter RegCdViolation by {{row(AppliedDate_2.selection, [0], [\"min\", \"max\"]).asDateRange(\"date('CreatedDate_Year', 'CreatedDate_Month', 'CreatedDate_Day')\")}};\r\nEnfAction_prev = filter EnfAction by {{row(AppliedDate_2.selection, [0], [\"min\", \"max\"]).asDateRange(\"date('CreatedDate_Year', 'CreatedDate_Month', 'CreatedDate_Day')\")}};\r\nPublicComplaint_prev = filter PublicComplaint by {{row(AppliedDate_2.selection, [0], [\"min\", \"max\"]).asDateRange(\"date('CreatedDate_Year', 'CreatedDate_Month', 'CreatedDate_Day')\")}};\r\n  \r\n---Cogroup all the streams\r\nresult = cogroup Insp_curr by all full, RegCdViolation_curr by all full, EnfAction_curr by all full,PublicComplaint_curr by all full, Insp_prev by all full, RegCdViolation_prev by all full, EnfAction_prev by all full,PublicComplaint_prev by all;\r\nresult = foreach result gen