y(\"AppliedDate_Month\")}};\r\nBizLicense = load \"BusinessLicense_FEN\";\r\nBizLicense = filter BizLicense by  {{cell(ExecHerVizPage1_1.selection, 0, \"AppliedDate_Month\").asEquality(\"PeriodStart_Month\")}};\r\n\r\nApps_curr = filter Apps by {{row(AppliedDate_1.selection, [0], [\"min\", \"max\"]).asDateRange(\"date('AppliedDate_Year', 'AppliedDate_Month', 'AppliedDate_Day')\")}};\r\nIndApps_curr = filter IndApps by {{row(AppliedDate_1.selection, [0], [\"min\", \"max\"]).asDateRange(\"date('AppliedDate_Year', 'AppliedDate_Month', 'AppliedDate_Day')\")}};\r\nBizLicenseApps_curr = filter BizLicenseApps by {{row(AppliedDate_1.selection, [0], [\"min\", \"max\"]).asDateRange(\"date('AppliedDate_Year', 'AppliedDate_Month', 'AppliedDate_Day')\")}};\r\nBizLicense_curr = filter BizLicense by {{row(AppliedDate_1.selection, [0], [\"min\", \"max\"]).asDateRange(\"date('PeriodStart_Year', 'PeriodStart_Month', 'PeriodStart_Day')\")}};\r\n\r\nApps_prev = filter Apps by {{row(AppliedDate_2.selection, [0], [\"min\", \"max\"]).asDateRange(\"date('AppliedDate_Year', 'AppliedDate_Month', 'AppliedDate_Day')\")}};\r\nIndApps_prev = filter IndApps by {{row(AppliedDate_2.selection, [0], [\"min\", \"max\"]).asDateRange(\"date('AppliedDate_Year', 'AppliedDate_Month', 'AppliedDate_Day')\")}};\r\nBizLicenseApps_prev = filter BizLicenseApps by {{row(AppliedDate_2.selection, [0], [\"min\", \"max\"]).asDateRange(\"date('AppliedDate_Year', 'AppliedDate_Month', 'AppliedDate_Day')\")}};\r\nBizLicense_prev = filter BizLicense by {{row(AppliedDate_2.selection, [0], [\"min\", \"max\"]).asDateRange(\"date('PeriodStart_Year', 'PeriodStart_Month', 'PeriodStart_Day')\")}};\r\n\r\nresult = cogroup Apps_curr by all full, IndApps_curr by all full, BizLicenseApps_curr by all full,BizLicense_curr by all full, Apps_prev by all full,IndApps_prev by all full, BizLicenseApps_prev by all full, BizLicense_prev by all;\r\nresult = foreach result generate count(Apps_curr) as 'TotalApps', count(IndApps_curr) as 'IndividualApplicationsCount', count(BizLicenseApps_curr) as 'BusinessApplicationsCount',count(BizLicense_curr) as 'BusinessLicenseCount', count(Apps_prev) as 'TotalApps_prev', count(BizLicenseApps_prev) as 'BusinessApplicationsCount_prev',count(IndApps_prev) as 'IndividualApplicationsCount_prev', count(BizLicense_prev) as 'BusinessLicenseCount_prev';\r\nfinal = foreach result generate 'TotalApps','IndividualApplicationsCount','BusinessApplicationsCount','BusinessLicenseCount','TotalApps_prev','BusinessApplicationsCount_prev','IndividualApplicationsCount_prev','BusinessLicenseCount_prev', ('TotalApps'- 'TotalApps_prev')/'TotalApps_prev' as 'perc_Apps_Change',('IndividualApplicationsCount'- 'IndividualApplicationsCount_prev')/'TotalApps_prev' as 'perc_IndvApps_Change',('BusinessApplicationsCount'- 'BusinessApplicationsCount_prev')/'BusinessApplicationsCount_prev' as 'perc_BusinessApps_Change',('BusinessLicenseCount'- 'BusinessLicenseCount_prev')/'BusinessLicenseCount_prev' as 'perc_BusinessLicense_Change';","receiveFacetSource":{"mode":"exclude","steps":["ExecHerVizPage1_1","AppliedDate_1","AppliedDate_2","HeroVizPage2_1","Top5AccountsFees_1","ByRegulatoryTransact_1","FeeByLicenseType_2","RegAuthName_1","ActualInspectionsByD_1","DonutVizPage3Direct_1","IspectionsComplaints_1","ViolationsByViolatio_1","ComplaintsByComplain_1","PlannedInspections_1","KPI_bar_Page3_1","Fee_from_Inspections_1","Fee_by_Assets_1","RegulatoryTransactio_1"]},"selectMode":"single","strings":[],"type":"saql","useExternalFilters":false,"useGlobal":true,"visualizationParameters":{"parameters":{"autoFitMode":"keepLabels","bins":{"breakpoints":{"high":100,"low":0},"bands":{"high":{"color":"#008000","label":""},"low":{"color":"#B22222","label":""},"medium":{"color":"#ffa500","label":""}}},"legend":{"descOrder":false,"showHeader":true,"show":true,"customSize":"auto","position":"right-top","inside":false},"axisMode":"multi","tooltip":{"content":{"legend":{"showBinLabel":true,"measures":[],"showNullValues":