ns_And_Viol_1.selection, 0, \"ActualStartTime_Year\").asEquality(\"ActualVisitStartTime_Year\")}} and {{cell(Inspections_And_Viol_1.selection, 0, \"ActualStartTime_Month\").asEquality(\"ActualVisitStartTime_Month\")}};\nresult = group q by ('Account.Name','InspectionType.Name', 'Status');\nresult = foreach result generate 'Account.Name',q.'InspectionType.Name' as 'InspectionType.Name', q.'Status' as 'Status', count(q) as 'Number_of_Inspections';\nresult = order result by 'Number_of_Inspections' desc;","receiveFacetSource":{"mode":"exclude","steps":["dateSelector_2"]},"selectMode":"single","strings":[],"type":"saql","useExternalFilters":false,"useGlobal":true,"visualizationParameters":{"parameters":{"borderColor":"#e0e5ee","borderWidth":1,"cell":{"backgroundColor":"#ffffff","fontColor":"#16325c","fontSize":12},"columnProperties":{},"columns":["Number_of_Inspections","Account.Name","InspectionType.Name","Status"],"customBulkActions":[],"header":{"backgroundColor":"#f4f6f9","fontColor":"#16325c","fontSize":12},"headerProperties":{},"innerMajorBorderColor":"#a8b7c7","innerMinorBorderColor":"#e0e5ee","interactions":[],"maxColumnWidth":300,"minColumnWidth":40,"mode":"variable","numberOfLines":1,"showActionMenu":true,"showRowIndexColumn":false,"verticalPadding":8},"type":"table"}},"KPI_Bar_1":{"broadcastFacet":true,"groups":[],"label":"KPI_Bar","numbers":[],"query":"Insp = load \"Inspection_FEN\";\r\nInsp= filter Insp by {{cell(Inspections_And_Viol_1.selection, 0, \"ActualStartTime_Month\").asEquality(\"ActualVisitStartTime_Month\")}};\r\nRegCdViolation = load \"RegulatoryCodeViolation_FEN\";\r\nRegCdViolation= filter RegCdViolation by {{cell(Inspections_And_Viol_1.selection, 0, \"ActualStartTime_Month\").asEquality(\"CreatedDate_Month\")}};\r\nEnfAction = load \"ViolationEnforcementAction_FEN\";\r\nEnfAction= filter EnfAction by {{cell(Inspections_And_Viol_1.selection, 0, \"ActualStartTime_Month\").asEquality(\"CreatedDate_Month\")}};\r\nTxnFee = load \"RegulatoryTransactionFee_FEN\";\r\nTxnFee= filter TxnFee by {{cell(Inspections_And_Viol_1.selection, 0, \"ActualStartTime_Month\").asEquality(\"CreatedDate_Month\")}};\r\nPublicComplaint = load \"PublicComplaint_FEN\";\r\nPublicComplaint= filter PublicComplaint by {{cell(Inspections_And_Viol_1.selection, 0, \"ActualStartTime_Month\").asEquality(\"CreatedDate_Month\")}};\r\n---Duration Data\r\nInsp_curr = filter Insp by {{row(dateSelector_1.selection, [0], [\"min\", \"max\"]).asDateRange(\"date('ActualVisitStartTime_Year', 'ActualVisitStartTime_Month', 'ActualVisitStartTime_Day')\")}};\r\nRegCdViolation_curr = filter RegCdViolation by {{row(dateSelector_1.selection, [0], [\"min\", \"max\"]).asDateRange(\"date('CreatedDate_Year', 'CreatedDate_Month', 'CreatedDate_Day')\")}};\r\nEnfAction_curr = filter EnfAction by {{row(dateSelector_1.selection, [0], [\"min\", \"max\"]).asDateRange(\"date('CreatedDate_Year', 'CreatedDate_Month', 'CreatedDate_Day')\")}};\r\nTxnFee_curr = filter TxnFee by {{row(dateSelector_1.selection, [0], [\"min\", \"max\"]).asDateRange(\"date('CreatedDate_Year', 'CreatedDate_Month', 'CreatedDate_Day')\")}};\r\nPublicComplaint_curr = filter PublicComplaint by {{row(dateSelector_1.selection, [0], [\"min\", \"max\"]).asDateRange(\"date('CreatedDate_Year', 'CreatedDate_Month', 'CreatedDate_Day')\")}};\r\n---Compare to Duration\r\nInsp_prev = filter Insp by {{row(dateSelector_2.selection, [0], [\"min\", \"max\"]).asDateRange(\"date('ActualVisitStartTime_Year', 'ActualVisitStartTime_Month', 'ActualVisitStartTime_Day')\")}};\r\nRegCdViolation_prev = filter RegCdViolation by {{row(dateSelector_2.selection, [0], [\"min\", \"max\"]).asDateRange(\"date('CreatedDate_Year', 'CreatedDate_Month', 'CreatedDate_Day')\")}};\r\nEnfAction_prev = filter EnfAction by {{row(dateSelector_2.selection, [0], [\"min\", \"max\"]).asDateRange(\"date('CreatedDate_Year', 'CreatedDate_Month', 'CreatedDate_Day')\")}};\r\nTxnFee_prev = filter TxnFee by {{row(dateSelector_2.selection, [0], [\"min\", \"max\"]).asDateRange(\"date('CreatedDate_Year', 'CreatedDate_Month', 'CreatedDate_Day')\")}};\r\nPublicComplaint_prev = filter PublicComplaint by {{row(dateSelector_2.selection, [0], [\"min\", \"max\"]).asDateRange(\"date('CreatedDate_Year', 'CreatedDate_Month', 'CreatedDate_Day')\")}};\r\n---Cogroup all the streams\r\nresult = cogroup Insp_curr by all full, RegCdViolation_curr by all full, EnfAction_curr by all full,PublicComplaint_curr by all full, TxnFee_curr by all full,Insp_prev by all full, RegCdViolation_prev by all full, EnfAction_prev by all full,PublicComplaint_prev by all full, TxnFee_prev by all;\r\nresult = foreach result generate count(Insp_curr) as 'Total_Visits',count(RegCdViolation_curr) as 'Total_Violations',count(EnfAction_curr) as 'Total_EnfAction',count(PublicComplaint_curr) as 'Total_Complaints',sum(TxnFee_curr.'TotalFeeAmount') as 'Fee_Charged',count(Insp_prev) as 'Total_Visits_prev',count(RegCdViolation_prev) as 'Total_Violations_prev',count(EnfAction_prev) as 'Total_EnfAction_prev',count(PublicComplaint_prev) as 'Total_Complaints_prev',sum(TxnFee_prev.'TotalFeeAmount') as 'Fee_Charged_prev';\r\nfinal = foreach result generate 'Total_Visits','Total_Violations','Total_EnfAction','Total_Complaints','Fee_Charged','Total_Visits_prev','Total_Violations_prev','Total_Complaints_prev','Fee_Charged_prev',(('Total_Visits'- 'Total_Visits_prev')/'Total_Visits_prev') as 'perc_Visit_Change',(('Total_Violations'- 'Total_Violations_prev')/'Total_Violations_prev') as 'perc_Violations_Change',(('Total_EnfAction'- 'Total_EnfAction_prev')/'Total_EnfAction_prev') as 'perc_EnfAction_Change',(('Total_Complaints'- 'Total_Complaints_prev')/'Total_Complaints_prev') as 'perc_Complaints_Change',(('Fee_Charged'- 'Fee_Charged_prev')/'Fee_Charged_prev') as 'perc_Fee_Change';","receiveFacetSource":{"mode":"exclude","steps":["dateSelector_1","dateSelector_2"]},"selectMode":"single","strings":[],"type":"saql","useExternalFilters":false,"useGlobal":true,"visualizationParameters":{"parameters":{"borderColor":"#e0e5ee","borderWidth":1,"cell":{"backgroundColor":"#ffffff","fontColor":"#16325c","fontSize":12},"columnProperties":{},"columns":[],"customBulkActions":[],"header":{"backgroundColor":"#f4f6f9","fontColor":"#16325c","fontSize":12},"headerProperties":{},"innerMajorBorderColor":"#a8b7c7","innerMinorBorderColor":"#e0e5ee","interactions":[],"maxColumnWidth":300,"minColumnWidth":40,"mode":"variable","numberOfLines":1,"showActionMenu":true,"showRowIndexColumn":false,"totals":true,"verticalPadding":8},"type":"table"}},"EA_Details_1":{"broadcastFacet":true,"groups":[],"label":"EA_Details","numbers":[],"query":"q1 = load \"Account_FEN\";\nq2 = load \"ViolationEnforcementAction_FEN\";\nq2 = filter q2 by {{cell(Inspections_And_Viol_1.selection, 0, \"ActualStartTime_Year\").asEquality(\"CreatedDate_Year\")}} and {{cell(Inspections_And_Viol_1.selection, 0, \"ActualStartTime_Month\").asEquality(\"CreatedDate_Month\")}};\nq1 = group q1 by ('Id','Name');\nq2 = group q2 by ('RegCodeViolation.Inspection.AccountId','Type','Status');\nq = cogroup q2 by ('RegCodeViolation.Inspection.AccountId') left,q1 by ('Id');\nq = foreach q generate q1.'Name' as 'Name',q2.'Type' as 'Enforcement Action Type',q2.'Status' as 'Status',count(q2) as 'Total_Enforcement_Actions';\nq = order q by 'Total_Enforcement_Actions' desc;\nq = limit q 2000;","receiveFacetSource":{"mode":"exclude","steps":["dateSelector_2"]},"selectMode":"single","strings":[],"type":"saql","useExternalFilters":false,"useGlobal":true,"visualizationParameters":{"parameters":{"borderColor":"#e0e5ee","borderWidth":1,"cell":{"backgroundColor":"#ffffff","fontColor":"#16325c","fontSize":12},"columnProperties":{"Name":{"parameters":{"alignment":"left","styles":{"linkColor":"#006dcc"}},"type":"text"}},"columns":[],"customBulkActions":[],"header":{"backgroundColor":"#f4f6f9","fontColor":"#16325c","fontSize":12},"headerProperties":{},"innerMajorBorderColor":"#a8b7c7","innerMinorBorderColor":"#e0e5ee","interactions":[],"mode":"fittocontainer","numberOfLines":1,"showActionMenu":true,"showRowIndexColumn":false,"totals":true,"verticalPadding":8},"type":"table"}},"static_Inspection_Ty_1":{"broadcastFacet":true,"columns":{"Value":{"type":"string"},"chart_Type":{"type":"string"},"Display":{"type":"string"}},"label":"static_Inspection_Type_Toggle","selectMode":"singlerequired","start":"{\"Display\":[\"Status\"]}","type":"staticflex","values":["{\"Display\":\"Status\",\"Value\":\"Status\",\"chart_Type\":\"pie\"}","{\"Display\":\"Priority\",\"Value\":\"VisitPriority\",\"chart_Type\":\"pie\"}","{\"Display\":\"Context\",\"Value\":\"InspectionContextSource\",\"chart_Type\":\"treemap\"}"]},"Violation_Details_1":{"broadcastFacet":true,"groups":[],"label":"Violation_Details","numbers":[],"query":"q1 = load \"Account_FEN\";\nq2 = load \"RegulatoryCodeViolation_FEN\";\nq2= filter q2 by {{cell(Inspections_And_Viol_1.selection, 0, \"ActualStartTime_Year\").asEquality(\"CreatedDate_Year\")}} and {{cell(Inspections_And_Viol_1.selection, 0, \"ActualStartTime_Month\").asEquality(\"CreatedDate_Month\")}};\nq1 = group q1 by ('Id','Name');\nq2 = group q2 by ('Inspection.AccountId','ViolationType.Type', 'Status');\nq = cogroup q2 by ('Inspection.AccountId') left,q1 by ('Id');\nq = foreach q generate q1.'Name' as 'Name',q2.'ViolationType.Type' as 'Violation Type', q2.'Status' as 'Status',count(q2) as 'Total_Violations';\nq = order q by 'Total_Violations' desc;\nq = limit q 2000;\n\n\n\n\n\n\n\n","receiveFacetSource":{"mode":"exclude","steps":["dateSelector_2"]},"selectMode":"single","strings":[],"type":"saql","useExternalFilters":false,"useGlobal":true,"visualizationParameters":{"parameters":{"borderColor":"#e0e5ee","borderWidth":1,"cell":{"backgroundColor":"#ffffff","fontColor":"#16325c","fontSize":12},"columnProperties":{"Name":{"parameters":{"alignment":"left","styles":{"linkColor":"#006dcc"}},"type":"text"}},"columns":[],"customBulkActions":[],"header":{"backgroundColor":"#f4f6f9","fontColor":"#1632