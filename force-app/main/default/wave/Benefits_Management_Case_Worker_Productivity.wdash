 foreach q generate 'Id', 'Status', 'Priority', sum(first(statusAge)) over ([0..0] partition by all order by first('statusAge')) as 'CurrentEpochSec', coalesce(sum(first(statusAge)) over ([1..1] partition by all order by first('statusAge')), date_to_epoch(now())) as 'NewEpochSec', unique('Id') as 'uniqueId';\nq = foreach q generate 'Id', 'Status', 'Priority', 'CurrentEpochSec', 'NewEpochSec', daysBetween(toDate(CurrentEpochSec), toDate(NewEpochSec)) as 'DaysDiff', 'uniqueId';\nq = foreach q generate  'Id', 'Status','Priority', 'CurrentEpochSec', 'NewEpochSec',  'DaysDiff', case when 'DaysDiff'>=0 && 'DaysDiff'<=2 then \"1 0-2 Days\" when 'DaysDiff'>2 && 'DaysDiff'<=4 then \"2 3-4 Days\" when 'DaysDiff'>4 && 'DaysDiff'<=6 then \"3 5-6 Days\" when 'DaysDiff'>6 && 'DaysDiff'<=8 then \"4 7-8 Days\"  else  \"5 >8 Days\" end as 'DaysBucket', 'uniqueId';\nq = foreach q generate  'Id', 'Status', 'Priority', 'CurrentEpochSec', 'NewEpochSec',  'DaysDiff', (case 'DaysBucket' when \"1 0-2 Days\" then \"0-2 Days\" when \"2 3-4 Days\" then \"3-4 Days\" when \"3 5-6 Days\" then \"5-6 Days\" when \"4 7-8 Days\" then \"7-8 Days\"  else \">8 Days\" end) as 'Bucket', 'DaysBucket', 'uniqueId';\nq = order q by 'DaysBucket' asc;\nq = filter q by Status == \"{{cell(Status_1.selection, 0, \"Status\").asString()}}\";\nq = group q by ('DaysBucket', 'Bucket', 'Priority');\nq = foreach q generate 'Bucket', 'Priority', sum('uniqueId') as 'Number of Days', sum(sum('uniqueId')) over ([..] partition by all ) as 'Total_Count', sum('DaysDiff') as 'DaysDiff';\nq = foreach q generate 'Bucket','Priority', 'Number of Days'/'Total_Count' as 'Cases', 'Number of Days';","receiveFacetSource":{"mode":"exclude","steps":["Status_Filter_1","Status_1","Status_2","Status_3","Cases_Status_1"]},"selectMode":"single","start":"[]","strings":[],"type":"saql","useExternalFilters":false,"useGlobal":true,"visualizationParameters":{"parameters":{"autoFitMode":"keepLabels","legend":{"descOrder":false,"showHeader":false,"sh